<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ID + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID Alquiler"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estado"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Maquinaria -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maquinaria ID"
                android:textSize="12sp"
                android:textColor="@color/textColorSecondary" />
            <TextView
                android:id="@+id/tvDetalleMaquinaria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary" />
        </LinearLayout>

        <!-- Fechas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Inicio"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleFechaInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Fin"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleFechaFin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Costo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Costo Total"
                android:textSize="12sp"
                android:textColor="@color/textColorSecondary" />
            <TextView
                android:id="@+id/tvDetalleCosto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/statusActive" />
        </LinearLayout>

        <!-- Motivo Rechazo (condicional) -->
        <LinearLayout
            android:id="@+id/layoutMotivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivo de Rechazo"
                android:textSize="12sp"
                android:textColor="@color/textColorSecondary" />
            <TextView
                android:id="@+id/tvDetalleMotivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/error"
                android:background="#1AF44336"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Extensión (condicional) -->
        <LinearLayout
            android:id="@+id/layoutExtension"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Fin Solicitada"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleFechaFinSolicitada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Costo Adicional"
                    android:textSize="12sp"
                    android:textColor="@color/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetalleCostoAdicional"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mensaje informativo para acciones -->
        <TextView
            android:id="@+id/tvMensajeWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Para solicitar extensiones o realizar cambios, utiliza la plataforma web."
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            android:background="#0D1A47A1"
            android:padding="12dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
