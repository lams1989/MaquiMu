# ===================================
# Gradle
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/

# Compiled class files
*.class

# Log files
*.log
bootrun.log

# Package files
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ===================================
# Frontend (Node/Angular)
# ===================================
# Dependencies
node_modules/
/.pnp
.pnp.js

# Testing
/coverage

# Production builds
/dist
/tmp
/out-tsc
/bazel-out

# Angular
.angular/
.sass-cache/

# ===================================
